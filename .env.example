# ── RTSP stream credentials ───────────────────────────────────────────────────
# Used by go2rtc and the webapp to authenticate against ring-mqtt's RTSP server.
# These MUST match the livestream_user / livestream_pass set during Ring login.
# On first run: log in via the web UI at http://localhost:8080 — the credentials
# you enter there are saved automatically to ring-mqtt-data/config.json.
RTSP_USER=your@email.com
RTSP_PASS=yourringpassword
