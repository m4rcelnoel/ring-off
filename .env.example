# ── RTSP stream credentials ───────────────────────────────────────────────────
# Used by go2rtc and the webapp to authenticate against ring-mqtt's RTSP server.
# Set these to your Ring account email and password (the same credentials you
# use to log in to the Ring Off web UI at http://localhost:8080).
# Required for live streams to work — do not leave blank.
RTSP_USER=your@email.com
RTSP_PASS=yourringpassword
